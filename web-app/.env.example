# Sao chép thành .env.local (CRA không commit file .env chứa secret thật)

# Base URL API Spring Boot (có context-path /api/v1)
REACT_APP_API_BASE_URL=http://localhost:8080/api/v1

# Google OAuth — Web client (JavaScript) trong Google Cloud Console
REACT_APP_GOOGLE_CLIENT_ID=

# Phải khớp URI đã đăng ký làm Authorized redirect URI (ví dụ: http://localhost:3000/authenticate)
REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000/authenticate
